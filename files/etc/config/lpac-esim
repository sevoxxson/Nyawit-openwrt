config lpac-esim 'main'
	option apdu_backend 'mbim'
	option http_backend 'curl'
	option qmi_device '/dev/cdc-wdm0'
	option qmi_sim_slot '1'
	option sim_slot '1'
	option at_device '/dev/ttyUSB2'
	option mbim_device '/dev/cdc-wdm0'
	option mbim_proxy '1'
	option mbim_skip_slot_mapping '1'
	option custom_isd_r_aid 'A0000005591010FFFFFFFF8900000100'
	option reboot_method 'script'
	option modem_iface '1_1'
	option apdu_debug '0'
	option http_debug '0'
	option at_debug '0'
	option telegram_enabled '0'
	option telegram_bot_token ''
	option telegram_allowed_chat_id ''
	option telegram_poll_interval '2'
	option telegram_debug '0'
